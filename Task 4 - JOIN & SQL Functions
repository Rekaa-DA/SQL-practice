Task 4: JOIN & SQL Functions

-- INNER JOIN
SELECT 
    s.StudentName,
    c.CourseName
FROM Enrollments e
INNER JOIN Students s 
    ON e.StudentID = s.StudentID
INNER JOIN Courses c 
    ON e.CourseID = c.CourseID;

-- LEFT JOIN
SELECT 
    s.StudentName,
    e.CourseID
FROM Students s
LEFT JOIN Enrollments e 
    ON s.StudentID = e.StudentID;

-- RIGHT JOIN
SELECT 
    s.StudentName,
    e.CourseID
FROM Students s
RIGHT JOIN Enrollments e 
    ON s.StudentID = e.StudentID;

-- ROUND()
SELECT ROUND(123.4567, 2) AS rounded_value;

-- CONCAT()
SELECT CONCAT(StudentName, ' from ', City, '.') AS Full_Description
FROM Students;

-- LENGTH()
SELECT 
    StudentName,
    LENGTH(StudentName) AS Name_Length
FROM Students;

-- REPLACE()
SELECT 
    CourseName,
    REPLACE(CourseName, 'SQL', 'Database') AS Updated_CourseName
FROM Courses;

-- SUBSTRING()
SELECT 
    StudentName,
    SUBSTRING(StudentName, 1, 3) AS Code_Prefix
FROM Students;

-- UPPER & LOWER
SELECT UPPER(City) FROM Students;
SELECT LOWER(StudentName) FROM Students;

-- DATE FUNCTIONS
SELECT NOW();
SELECT DATEDIFF('2025-06-01', '2025-05-10');

Takeaways :

- Practiced INNER, LEFT, and RIGHT JOIN
- Understood how to combine data from multiple tables
- Used string functions (CONCAT, LENGTH, REPLACE, SUBSTRING)
- Learned case conversion using UPPER and LOWER
- Worked with numeric function ROUND()
- Used date functions like NOW() and DATEDIFF()
