USE Hospital;

CREATE TABLE Patients(
    PatientID INT,
    PatientName VARCHAR(15),
    Age INT,
    Gender VARCHAR(10),
    AdmissionDate DATE
);

ALTER TABLE Patients ADD COLUMN DoctorAssigned VARCHAR(50);
